<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.dzritv"
       name="DZRI TV"
       version="0.2.1"
       provider-name="TopperBG">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Live sports streams from DZRI TV</summary>
        <description lang="en_GB">Browse live DZRI TV events by sport and play the available HLS streams.</description>
        <platform>all</platform>
        <license>MIT</license>
    </extension>
</addon>
